<%- include('layout', { body: `
<section style="max-width: 800px;">
    <h1><%= article.title %></h1>
    <% if (article.image_url) { %>
        <img src="<%= article.image_url %>" alt="<%= article.title %>" style="width: 100%; margin: 2rem 0; border-radius: 8px;">
    <% } %>
    <div style="color: #64748b; font-size: 0.9rem; margin-bottom: 2rem;">
        <span><%= article.category %></span> | 
        <span>۱۴۰۴</span> | 
        <span><%= article.views %> بازدید</span>
    </div>
    <div style="line-height: 1.8; color: #1e293b;">
        <%- article.content %>
    </div>
    <div style="margin-top: 3rem; padding-top: 2rem; border-top: 1px solid #e2e8f0;">
        <a href="/blog" class="btn btn-secondary">بازگشت به مقالات</a>
    </div>
</section>
` }) %>